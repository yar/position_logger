<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Unofficial.OpenVR" Version="1.1.0" />
    <PackageReference Include="unofficial-flayan-openvr.redist" Version="1.0.9" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(NuGetPackageRoot)unofficial-flayan-openvr.redist\\1.0.9\\build\\native\\bin\\x64\\dynamic\\openvr_api.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
